# Server
PORT=5000
NODE_ENV=development

# Database - MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=pfe_user
DB_PASSWORD=pfe_password123  
DB_NAME=bank_queue_pfe

# Comment out SQLite (not needed)
# DB_STORAGE=./database/bank_queue.db

# JWT
JWT_SECRET=bank-queue-secret-2024-change-in-production
JWT_EXPIRES_IN=24h

# Frontend
FRONTEND_URL=http://localhost:3000

# WebSocket
WEBSOCKET_PORT=5000

# Security
BCRYPT_SALT_ROUNDS=12

# Email (OPTIONAL - you can ignore these)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password